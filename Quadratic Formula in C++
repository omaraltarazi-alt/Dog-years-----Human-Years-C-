#include <iostream>
#include <cmath>
using namespace std;
int main() {
  double a, b, c;
  cout << " Please enter a: ";
  cin >> a;

  cout << " Please enter b: ";
  cin >> b;

  cout << " Please enter c: ";
  cin >> c;

double root1;
double root2;


root1 = (-b + sqrt(b*b - 4*a*c)) / (2*a);

root2 = (-b - sqrt(b*b - 4*a*c)) / (2*a);

cout << " Root 1 is " << root1 << "\n";
cout << " Root 2 is " << root2 << "\n";




  
  
}
